# ============================================
# PYTHON & DJANGO IGNORE RULES
# ============================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual environment
venv/
env/
ENV/
.venv/
.virtualenv/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
pytest_cache/
coverage.xml
nosetests.xml
*.cover
*.py,cover
.hypothesis/

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Migrations (OPTIONAL — keep if you want to store migrations)
# If you want migrations in Git, DELETE the line below
# */migrations/
# But ALWAYS ignore __pycache__ inside migrations:
*/migrations/__pycache__/

# Static and media (generated)
staticfiles/
static/
media/

# If using Django collectstatic
static_root/
media_root/

# IDE / Editor / OS files
.idea/
.vscode/
.vs/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Environment variables
.env
*.env

# JetBrains IDE (PyCharm)
*.iml
*.ipr
*.iws

# Jupyter Notebook Checkpoints
.ipynb_checkpoints/

# Gunicorn logs
*.pid

# Local testing files
.env.local
.env.development
.env.production

# Docker (if using)
docker-compose.override.yml
docker-compose.dev.yml

# Node modules (if frontend inside project)
node_modules/
npm-debug.log

# Cache generated by Django Debug Toolbar
debug_toolbar/

# SQLite backups
*.bak
*.sqlite3

# Python wheels
*.whl

# MyPy
.mypy_cache/

# Pylint
.pylint.d/

# pytest
.pytest_cache/

# VSCode Python settings
.vscode/settings.json
